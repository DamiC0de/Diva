{
  "expo": {
    "name": "Diva",
    "slug": "diva",
    "version": "0.1.0",
    "scheme": "diva",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": true,
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Diva a besoin du micro pour écouter ta voix et détecter le mot-clé \"Diva\".",
        "NSSpeechRecognitionUsageDescription": "Diva utilise la reconnaissance vocale pour détecter quand tu dis \"Diva\" et comprendre tes demandes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5856D6",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "userInterfaceStyle": "automatic",
      "package": "com.diva.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "./modules/notification-reader/app.plugin",
      "./plugins/withDivaWidget"
    ],
    "extra": {
      "eas": {
        "projectId": "diva-keyboard"
      }
    }
  }
}
